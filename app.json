{
  "expo": {
    "name": "sproutly",
    "slug": "sproutly",
    "scheme": "sproutly",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "config": {
        "usesNonExemptEncryption": false
      },
      "bundleIdentifier": "com.dottibug.sproutly"
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.dottibug.sproutly"
    },
    "plugins": ["expo-router", "expo-secure-store", "@react-native-community/datetimepicker", "expo-font", "expo-notifications"],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d7ce7304-6dec-4dd7-9478-ef51c6ff7fd4"
      }
    }
  }
}
